# Please Note:
# In PHP Versions <= 7.4 MySQL8 is not supported due to lacking pdo support

#Liniux User ID (set from server to container) linux terminal: "echo $UID"
#!!! DON'T use root uid and guid
UID=1000

#Linux group id (set from server to container) linux terminal: "echo $GID"
#!!! DON'T use root uid and guid
GID=1002

# To determine the name of your containers
#COMPOSE_PROJECT_NAME=books

# If you already have the port 80 in use, you can change it (for example if you have Apache)
HOST_MACHINE_UNSECURE_HOST_PORT=80

# If you already have the port 443 in use, you can change it (for example if you have Apache)
HOST_MACHINE_SECURE_HOST_PORT=443

# If you already have the port 3306 in use, you can change it (for example if you have MySQL)
HOST_MACHINE_MYSQL_PORT=3306

# If you already have the port 3306 in use, you can change it (for example if you have MySQL)
HOST_MACHINE_POSTGRESQL_PORT=5432

# If you already have the port 8080 in use, you can change it (for example if you have PMA)
HOST_MACHINE_PMA_PORT=8080

# If you already has the port 6379 in use, you can change it (for example if you have Redis)
HOST_MACHINE_REDIS_PORT=6379

# XDebug
; HOST_MACHINE_XDEBUG=6379
HOST_MACHINE_XDEBUG=9003

# Database settings: Username, password and database name
#POSTGRESQL

HOST_POSTGRESQL_UNIX_SYSTEM_USER=www-data
HOST_POSTGRESQL_DB=staffliner
HOST_POSTGRESQL_USER=docker
HOST_POSTGRESQL_PASSWORD=docker

#MYSQL
MYSQL_DATABASE=books
MYSQL_ROOT_PASSWORD=books
MYSQL_USER=books
MYSQL_PASSWORD=books
HOST_MACHINE_MYSQL_PORT=8080
